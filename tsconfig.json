{
  "compilerOptions": {
    "target": "ES2017",

    "module": "Node16",
    "moduleResolution": "node16",

    "rootDir": "./src",
    "outDir": "./lib",

    "declaration": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/__tests__/*"]
}